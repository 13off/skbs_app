{$PROXY_DOMAIN} {
  encode zstd gzip

  @health path /proxy-health
  respond @health "ok" 200

  reverse_proxy https://{$SUPABASE_UPSTREAM} {
    header_up Host {$SUPABASE_UPSTREAM}

    transport http {
      tls_server_name {$SUPABASE_UPSTREAM}
      keepalive 30s
      dial_timeout 10s
      response_header_timeout 30s
    }
  }

  log {
    output stdout
    format console
  }
}
