{
  "schema_version": 3,
  "principles": {
    "server_is_authoritative": true,
    "active_company_required": true,
    "active_membership_required": true,
    "role_preview_never_changes_server_identity": true,
    "live_acceptance_requires_real_role_account": true,
    "acceptance_is_read_only": true,
    "live_acceptance_uses_multiple_rls_probes": true,
    "foreman_scope_is_verified_without_client_filter": true
  },
  "roles": [
    {
      "role": "admin",
      "title": "Администратор",
      "platform": "ManagerMainScreen",
      "object_scope": "company",
      "can_preview_roles": true,
      "capabilities": [
        "objects.manage",
        "employees.manage",
        "attendance.manage",
        "tasks.manage",
        "payments.manage",
        "recruitment.manage",
        "reports.read",
        "company.manage"
      ],
      "acceptance": {
        "live_probe_table": "objects",
        "live_probe_tables": [
          "objects",
          "employees",
          "tasks",
          "attendance",
          "payments"
        ],
        "required_permissions": [
          "objects.view",
          "employees.view",
          "attendance.view",
          "tasks.view",
          "accounting.payments.view",
          "reports.view",
          "notifications.center.view",
          "ai.use",
          "system.roles.manage",
          "system.audit.view"
        ],
        "forbidden_permissions": []
      }
    },
    {
      "role": "developer",
      "title": "Разработчик",
      "platform": "DeveloperMainScreen",
      "object_scope": "company",
      "can_preview_roles": true,
      "capabilities": [
        "system.inspect",
        "dispatcher.manage",
        "object_policies.manage",
        "constructor.manage",
        "roles.preview",
        "reports.read"
      ],
      "acceptance": {
        "live_probe_table": "company_task_policies",
        "live_probe_tables": [
          "company_task_policies",
          "objects",
          "employees",
          "tasks",
          "payments"
        ],
        "required_permissions": [
          "system.settings.manage",
          "system.roles.manage",
          "system.audit.view",
          "system.recycle_bin.manage",
          "objects.view",
          "employees.view",
          "tasks.view",
          "accounting.payments.view",
          "ai.use"
        ],
        "forbidden_permissions": []
      }
    },
    {
      "role": "foreman",
      "title": "Прораб",
      "platform": "ForemanMainScreen",
      "object_scope": "assigned_object",
      "can_preview_roles": false,
      "capabilities": [
        "attendance.assigned_object",
        "tasks.assigned_object",
        "employees.assigned_object.read"
      ],
      "denied": [
        "payments.read",
        "recruitment.private.read",
        "objects.manage"
      ],
      "acceptance": {
        "live_probe_table": "objects",
        "live_probe_tables": [
          "objects",
          "tasks",
          "employees"
        ],
        "required_permissions": [
          "objects.view",
          "employees.view",
          "attendance.view",
          "attendance.edit",
          "tasks.view",
          "tasks.create",
          "tasks.edit",
          "tasks.photos.manage",
          "notifications.center.view",
          "ai.use"
        ],
        "forbidden_permissions": [
          "accounting.payments.view",
          "employees.create",
          "employees.delete",
          "attendance.delete",
          "recruitment.documents.view",
          "system.roles.manage",
          "system.audit.view"
        ],
        "requires_assigned_object": true,
        "probe_without_client_object_filter": true
      }
    },
    {
      "role": "hr",
      "title": "HR-менеджер",
      "platform": "RecruitmentMainScreen",
      "object_scope": "company",
      "can_preview_roles": false,
      "capabilities": [
        "recruitment.manage",
        "candidate_documents.manage",
        "employees.create"
      ],
      "denied": [
        "payments.manage",
        "object_policies.manage"
      ],
      "acceptance": {
        "live_probe_table": "recruitment_applications",
        "live_probe_tables": [
          "recruitment_applications",
          "recruitment_documents",
          "employees"
        ],
        "required_permissions": [
          "recruitment.applications.view",
          "recruitment.documents.edit",
          "recruitment.messages.send",
          "recruitment.mobilization.edit",
          "documents.templates.view",
          "employees.view",
          "notifications.center.view",
          "ai.use"
        ],
        "forbidden_permissions": [
          "accounting.payments.view",
          "attendance.edit",
          "tasks.edit",
          "legal.documents.edit",
          "system.roles.manage"
        ]
      }
    },
    {
      "role": "accountant",
      "server_aliases": [
        "accounting"
      ],
      "title": "Бухгалтер",
      "platform": "AccountingMainScreen",
      "object_scope": "company",
      "can_preview_roles": false,
      "capabilities": [
        "payments.manage",
        "payment_receipts.manage",
        "employees.payment_fields.read"
      ],
      "denied": [
        "candidate_documents.manage",
        "objects.manage"
      ],
      "acceptance": {
        "live_probe_table": "payments",
        "live_probe_tables": [
          "payments",
          "attendance",
          "employees"
        ],
        "required_permissions": [
          "accounting.attendance.view",
          "accounting.payments.view",
          "accounting.payments.edit",
          "accounting.receipts.view",
          "accounting.receipts.edit",
          "employees.view",
          "objects.view",
          "reports.view",
          "notifications.center.view"
        ],
        "forbidden_permissions": [
          "employees.edit",
          "attendance.edit",
          "tasks.edit",
          "recruitment.documents.edit",
          "legal.documents.edit",
          "system.roles.manage"
        ]
      }
    },
    {
      "role": "lawyer",
      "title": "Юрист",
      "platform": "LegalMainScreen",
      "object_scope": "company",
      "can_preview_roles": false,
      "capabilities": [
        "legal.manage",
        "employees.directory.read",
        "objects.directory.read"
      ],
      "denied": [
        "candidate_documents.private.read",
        "payments.private.read"
      ],
      "acceptance": {
        "live_probe_table": "legal_documents",
        "live_probe_tables": [
          "legal_documents",
          "legal_matters",
          "objects"
        ],
        "required_permissions": [
          "legal.documents.view",
          "legal.documents.edit",
          "legal.files.view",
          "legal.matters.view",
          "legal.reports.view",
          "personal_data.compliance.view",
          "documents.templates.view",
          "objects.view",
          "notifications.center.view"
        ],
        "forbidden_permissions": [
          "accounting.payments.view",
          "employees.edit",
          "attendance.edit",
          "tasks.edit",
          "recruitment.documents.edit",
          "system.roles.manage"
        ]
      }
    }
  ]
}
