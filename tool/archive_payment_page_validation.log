              '                        style: TextStyle(\n'
              '                          color: _text,\n'
              '                          fontSize: 22,\n'
              '                          fontWeight: FontWeight.w900,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                    IconButton(\n'
              '                      tooltip: \'Архив объектов\',\n'
              '                      onPressed: () {\n'
