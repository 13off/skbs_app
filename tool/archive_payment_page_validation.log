              '                                    );\n'
              '\n'
              '                                    if (!sheetContext.mounted) return;\n'
              '                                    Navigator.pop(sheetContext);\n'
              '                                    refreshObjectsAndDashboard();\n'
              '\n'
              '                                    if (!mounted) return;\n'
              '                                    ScaffoldMessenger.of(\n'
              '                                      this.context,\n'
              '                                    ).showSnackBar(\n'
              '                                      SnackBar(\n'
              '                                        content: Text(\n'
              '                                          \'Объект "$objectName" восстановлен\',\n'
              '                                        ),\n'
              '                                      ),\n'
              '                                    );\n'
              '                                  } catch (error) {\n'
              '                                    if (!sheetContext.mounted) return;\n'
              '\n'
              '                                    ScaffoldMessenger.of(\n'
              '                                      sheetContext,\n'
              '                                    ).showSnackBar(\n'
              '                                      SnackBar(content: Text(error.toString())),\n'
              '                                    );\n'
              '                                  }\n'
              '                                },\n'
              '                                icon: const Icon(Icons.restore, size: 18),\n'
              '                                label: const Text(\'Вернуть\'),\n'
              '                              ),\n'
              '                            ],\n'
              '                          ),\n'
              '                        );\n'
              '                      },\n'
              '                    ),\n'
              '                  ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Future<void> showObjectPicker(\n'
              '    BuildContext context,\n'
              '    List<String> objects,\n'
              '  ) async {\n'
              '    if (!widget.profile.isAdmin) return;\n'
