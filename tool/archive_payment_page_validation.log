              '              boxShadow: [\n'
              '                BoxShadow(\n'
              '                  color: Colors.black.withValues(alpha: 0.10),\n'
              '                  blurRadius: 28,\n'
              '                  offset: const Offset(0, 14),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
