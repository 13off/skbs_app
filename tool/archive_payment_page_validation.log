              '                else\n'
              '                  Flexible(\n'
              '                    child: ListView.separated(\n'
              '                      shrinkWrap: true,\n'
              '                      itemCount: archivedObjects.length,\n'
              '                      separatorBuilder: (_, _) => const SizedBox(height: 10),\n'
              '                      itemBuilder: (context, index) {\n'
              '                        final objectName = archivedObjects[index];\n'
              '\n'
