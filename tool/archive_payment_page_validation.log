              '\n'
              '      ScaffoldMessenger.of(\n'
              '        this.context,\n'
              '      ).showSnackBar(SnackBar(content: Text(error.toString())));\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (!context.mounted) return;\n'
              '\n'
              '    await showModalBottomSheet<void>(\n'
              '      context: context,\n'
