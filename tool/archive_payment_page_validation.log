              '                            border: Border.all(color: _line),\n'
              '                          ),\n'
              '                          child: Row(\n'
              '                            children: [\n'
              '                              const Icon(Icons.inventory_2_outlined),\n'
              '                              const SizedBox(width: 12),\n'
              '                              Expanded(\n'
              '                                child: Text(\n'
              '                                  objectName,\n'
              '                                  overflow: TextOverflow.ellipsis,\n'
              '                                  style: const TextStyle(\n'
              '                                    color: _text,\n'
              '                                    fontWeight: FontWeight.w900,\n'
              '                                  ),\n'
              '                                ),\n'
              '                              ),\n'
              '                              TextButton.icon(\n'
              '                                onPressed: () async {\n'
              '                                  try {\n'
              '                                    await ObjectRepository.restoreObject(\n'
