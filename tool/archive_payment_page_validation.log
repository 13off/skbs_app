              '    };\n'
              '\n'
              '    if (!mounted || !change.affectsAny(dashboardDomains)) return;\n'
              '\n'
              '    final refreshObjects = change.affects(AppDataDomain.objects);\n'
              '\n'
              '    setState(() {\n'
              '      if (refreshObjects) {\n'
              '        objectNamesFuture = EmployeeRepository.fetchObjectNames(\n'
              '          forceRefresh: true,\n'
              '        );\n'
              '      }\n'
              '      dashboardFuture = loadDashboardData(forceRefresh: true);\n'
              '    });\n'
              '  }\n'
              '\n'
              '  String? cleanObjectName(String? value) {\n'
              '    final clean = value?.trim();\n'
              '\n'
              '    if (clean == null || clean.isEmpty) return null;\n'
              '\n'
              '    return clean;\n'
              '  }\n'
              '\n'
              '  String normalizeName(String value) {\n'
              '    return value.trim().toLowerCase().replaceAll(RegExp(r\'\\s+\'), \' \');\n'
              '  }\n'
              '\n'
              '  String get objectTitle {\n'
              '    return cleanObjectName(widget.selectedObjectName) ?? \'Все объекты\';\n'
              '  }\n'
              '\n'
              '  String dateText(DateTime date) {\n'
              '    const months = [\n'
              '      \'января\',\n'
              '      \'февраля\',\n'
              '      \'марта\',\n'
              '      \'апреля\',\n'
              '      \'мая\',\n'
              '      \'июня\',\n'
              '      \'июля\',\n'
              '      \'августа\',\n'
              '      \'сентября\',\n'
              '      \'октября\',\n'
              '      \'ноября\',\n'
              '      \'декабря\',\n'
              '    ];\n'
              '\n'
              '    return \'${date.day} ${months[date.month - 1]}\';\n'
              '  }\n'
              '\n'
              '  bool isSameObject(String? first, String? second) {\n'
              '    return cleanObjectName(first) == cleanObjectName(second);\n'
              '  }\n'
              '\n'
              '  bool isSameFinancePeriod(FinancePeriod first, FinancePeriod second) {\n'
              '    return first.year == second.year && first.month == second.month;\n'
              '  }\n'
              '\n'
              '  Future<_HomeDashboardData> loadDashboardData({\n'
              '    bool forceRefresh = false,\n'
              '  }) async {\n'
              '    final today = AppState.today;\n'
              '    final selectedObject = cleanObjectName(widget.selectedObjectName);\n'
              '\n'
              '    final results = await Future.wait<dynamic>([\n'
              '      EmployeeRepository.fetchEmployees(\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      AttendanceRepository.fetchWorkedEmployeeIds(\n'
              '        today,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      TaskRepository.fetchTasksForDate(\n'
              '        today,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      FinanceSummaryRepository.fetchSummary(\n'
              '        period: financePeriod,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      if (selectedObject == null)\n'
              '        ObjectRepository.fetchObjectNames(forceRefresh: forceRefresh),\n'
              '    ]);\n'
              '\n'
              '    final employees = results[0] as List<Employee>;\n'
              '    final workedEmployeeIds = results[1] as Set<String>;\n'
              '    var tasks = results[2] as List<TaskItemData>;\n'
              '\n'
              '    if (selectedObject == null) {\n'
              '      final activeObjectNames = (results[4] as List<String>).toSet();\n'
              '      tasks = tasks\n'
              '          .where((task) => activeObjectNames.contains(task.objectName.trim()))\n'
              '          .toList();\n'
              '    }\n'
              '\n'
              '    return _HomeDashboardData(\n'
              '      employees: employees,\n'
              '      workedEmployeeIds: workedEmployeeIds,\n'
              '      tasks: tasks,\n'
              '      finance: results[3] as FinanceSummaryData,\n'
              '    );\n'
              '  }\n'
              '\n'
              '  void refreshObjectsAndDashboard() {\n'
              '    ObjectRepository.clearCache();\n'
              '    EmployeeRepository.clearCache();\n'
              '    AttendanceRepository.clearCache();\n'
              '    TaskRepository.clearTaskListCache();\n'
              '    FinanceSummaryRepository.clearCache();\n'
              '\n'
              '    if (!mounted) return;\n'
              '\n'
              '    setState(() {\n'
              '      objectNamesFuture = EmployeeRepository.fetchObjectNames(\n'
              '        forceRefresh: true,\n'
              '      );\n'
              '      dashboardFuture = loadDashboardData(forceRefresh: true);\n'
              '    });\n'
              '  }\n'
              '\n'
              '  Future<String?> showObjectNameSheet({String? currentName}) async {\n'
              '    if (!widget.profile.isAdmin) return null;\n'
              '\n'
              '    final isEdit = currentName != null;\n'
              '    final formKey = GlobalKey<FormState>();\n'
              '    final controller = TextEditingController(text: currentName ?? \'\');\n'
              '    var isSaving = false;\n'
              '    String? errorText;\n'
              '\n'
              '    final result = await showModalBottomSheet<String>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return StatefulBuilder(\n'
              '          builder: (context, setModalState) {\n'
              '            Future<void> saveObject() async {\n'
              '              final isValid = formKey.currentState?.validate() ?? false;\n'
              '\n'
              '              if (!isValid || isSaving) return;\n'
              '\n'
              '              setModalState(() {\n'
              '                isSaving = true;\n'
              '                errorText = null;\n'
              '              });\n'
              '\n'
              '              try {\n'
              '                final savedName = isEdit\n'
              '                    ? await ObjectRepository.renameObject(\n'
              '                        oldName: currentName,\n'
              '                        newName: controller.text,\n'
              '                      )\n'
              '                    : await ObjectRepository.addObject(name: controller.text);\n'
              '\n'
              '                if (!sheetContext.mounted) return;\n'
              '                Navigator.pop(sheetContext, savedName);\n'
              '              } catch (error) {\n'
              '                if (!sheetContext.mounted) return;\n'
              '\n'
              '                setModalState(() {\n'
              '                  isSaving = false;\n'
              '                  errorText = error.toString();\n'
              '                });\n'
              '              }\n'
              '            }\n'
              '\n'
              '            return SafeArea(\n'
              '              child: Padding(\n'
              '                padding: EdgeInsets.only(\n'
              '                  left: 12,\n'
              '                  right: 12,\n'
              '                  top: 12,\n'
              '                  bottom: 12 + MediaQuery.of(context).viewInsets.bottom,\n'
              '                ),\n'
              '                child: Container(\n'
              '                  padding: const EdgeInsets.all(18),\n'
              '                  decoration: BoxDecoration(\n'
              '                    color: _card,\n'
              '                    borderRadius: BorderRadius.circular(28),\n'
              '                    border: Border.all(color: _line),\n'
              '                    boxShadow: [\n'
              '                      BoxShadow(\n'
              '                        color: Colors.black.withValues(alpha: 0.10),\n'
              '                        blurRadius: 28,\n'
              '                        offset: const Offset(0, 14),\n'
              '                      ),\n'
              '                    ],\n'
              '                  ),\n'
              '                  child: Form(\n'
              '                    key: formKey,\n'
              '                    child: Column(\n'
              '                      mainAxisSize: MainAxisSize.min,\n'
              '                      crossAxisAlignment: CrossAxisAlignment.start,\n'
              '                      children: [\n'
              '                        Center(\n'
              '                          child: Container(\n'
              '                            width: 44,\n'
              '                            height: 5,\n'
              '                            decoration: BoxDecoration(\n'
              '                              color: const Color(0xFFD4CCC2),\n'
              '                              borderRadius: BorderRadius.circular(100),\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                        const SizedBox(height: 18),\n'
              '                        Row(\n'
              '                          children: [\n'
              '                            Expanded(\n'
              '                              child: Text(\n'
              '                                isEdit\n'
              '                                    ? \'Редактировать объект\'\n'
              '                                    : \'Новый объект\',\n'
              '                                style: const TextStyle(\n'
              '                                  color: _text,\n'
              '                                  fontSize: 22,\n'
              '                                  fontWeight: FontWeight.w900,\n'
              '                                ),\n'
              '                              ),\n'
              '                            ),\n'
              '                            IconButton(\n'
              '                              onPressed: isSaving\n'
              '                                  ? null\n'
              '                                  : () => Navigator.pop(sheetContext),\n'
              '                              icon: const Icon(Icons.close),\n'
              '                            ),\n'
              '                          ],\n'
              '                        ),\n'
              '                        const SizedBox(height: 14),\n'
              '                        TextFormField(\n'
              '                          controller: controller,\n'
              '                          enabled: !isSaving,\n'
              '                          autofocus: true,\n'
              '                          textCapitalization: TextCapitalization.words,\n'
              '                          decoration: InputDecoration(\n'
              '                            labelText: \'Название объекта\',\n'
              '                            hintText: isEdit ? currentName : \'Например: Талнах\',\n'
              '                            border: const OutlineInputBorder(),\n'
              '                            prefixIcon: const Icon(Icons.business_outlined),\n'
              '                          ),\n'
              '                          validator: (value) {\n'
              '                            final text = value?.trim() ?? \'\';\n'
              '\n'
              '                            if (text.isEmpty) {\n'
              '                              return \'Введите название объекта\';\n'
              '                            }\n'
              '\n'
              '                            if (text.length < 2) {\n'
              '                              return \'Название слишком короткое\';\n'
              '                            }\n'
              '\n'
              '                            return null;\n'
              '                          },\n'
              '                          onFieldSubmitted: (_) => saveObject(),\n'
              '                        ),\n'
              '                        if (errorText != null) ...[\n'
              '                          const SizedBox(height: 12),\n'
              '                          Text(\n'
              '                            errorText!,\n'
              '                            style: const TextStyle(\n'
              '                              color: Colors.red,\n'
              '                              fontWeight: FontWeight.w700,\n'
              '                            ),\n'
              '                          ),\n'
              '                        ],\n'
              '                        const SizedBox(height: 16),\n'
              '                        SizedBox(\n'
              '                          width: double.infinity,\n'
              '                          height: 52,\n'
              '                          child: FilledButton.icon(\n'
              '                            onPressed: isSaving ? null : saveObject,\n'
              '                            icon: isSaving\n'
              '                                ? const SizedBox(\n'
              '                                    width: 18,\n'
              '                                    height: 18,\n'
              '                                    child: CircularProgressIndicator(\n'
              '                                      strokeWidth: 2,\n'
              '                                    ),\n'
              '                                  )\n'
              '                                : Icon(\n'
              '                                    isEdit\n'
              '                                        ? Icons.save_outlined\n'
              '                                        : Icons.add_business_outlined,\n'
              '                                  ),\n'
              '                            label: Text(\n'
              '                              isSaving\n'
              '                                  ? \'Сохраняем...\'\n'
              '                                  : isEdit\n'
              '                                  ? \'Сохранить\'\n'
              '                                  : \'Создать\',\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                      ],\n'
              '                    ),\n'
              '                  ),\n'
              '                ),\n'
              '              ),\n'
              '            );\n'
              '          },\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    controller.dispose();\n'
              '    return result;\n'
              '  }\n'
              '\n'
              '  Future<void> handleAddObject() async {\n'
              '    final createdName = await showObjectNameSheet();\n'
              '\n'
              '    if (createdName == null || createdName.trim().isEmpty) return;\n'
              '\n'
              '    widget.onObjectChanged(createdName);\n'
              '    refreshObjectsAndDashboard();\n'
              '  }\n'
              '\n'
              '  Future<void> handleRenameObject(String oldName) async {\n'
              '    final newName = await showObjectNameSheet(currentName: oldName);\n'
              '\n'
              '    if (newName == null || newName.trim().isEmpty) return;\n'
              '\n'
              '    if (isSameObject(widget.selectedObjectName, oldName)) {\n'
              '      widget.onObjectChanged(newName);\n'
              '    }\n'
              '\n'
              '    refreshObjectsAndDashboard();\n'
              '  }\n'
              '\n'
              '  Future<void> handleArchiveObject(String objectName) async {\n'
              '    final confirmed = await showDialog<bool>(\n'
              '      context: context,\n'
              '      builder: (dialogContext) {\n'
              '        return AlertDialog(\n'
              '          title: const Text(\'Архивировать объект?\'),\n'
              '          content: Text(\n'
              '            \'Объект "$objectName" исчезнет из рабочего списка. Табели, задачи, выплаты и документы сохранятся. Сотрудники на этом объекте будут отмечены как уволенные.\',\n'
              '          ),\n'
              '          actions: [\n'
              '            TextButton(\n'
              '              onPressed: () => Navigator.pop(dialogContext, false),\n'
              '              child: const Text(\'Отмена\'),\n'
              '            ),\n'
              '            FilledButton.icon(\n'
              '              onPressed: () => Navigator.pop(dialogContext, true),\n'
              '              icon: const Icon(Icons.archive_outlined),\n'
              '              label: const Text(\'В архив\'),\n'
              '            ),\n'
              '          ],\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (confirmed != true) return;\n'
              '\n'
              '    try {\n'
              '      final wasSelected = isSameObject(widget.selectedObjectName, objectName);\n'
              '\n'
              '      await ObjectRepository.archiveObject(name: objectName);\n'
              '\n'
              '      if (wasSelected) {\n'
              '        widget.onObjectChanged(null);\n'
              '      }\n'
              '\n'
              '      refreshObjectsAndDashboard();\n'
              '\n'
              '      if (!mounted) return;\n'
              '\n'
              '      ScaffoldMessenger.of(context).showSnackBar(\n'
              '        SnackBar(content: Text(\'Объект "$objectName" перемещён в архив\')),\n'
              '      );\n'
              '    } catch (error) {\n'
              '      if (!mounted) return;\n'
              '\n'
              '      ScaffoldMessenger.of(\n'
              '        context,\n'
              '      ).showSnackBar(SnackBar(content: Text(error.toString())));\n'
              '    }\n'
              '  }\n'
              '\n'
              '  Future<void> showArchivedObjectsSheet(BuildContext context) async {\n'
              '    List<String> archivedObjects;\n'
              '\n'
              '    try {\n'
              '      archivedObjects = await ObjectRepository.fetchArchivedObjectNames(\n'
              '        forceRefresh: true,\n'
              '      );\n'
