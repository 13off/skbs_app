              '                const SizedBox(height: 10),\n'
              '                Flexible(\n'
              '                  child: ListView(\n'
              '                    shrinkWrap: true,\n'
              '                    children: [\n'
              '                      _ObjectPickerTile(\n'
              '                        title: \'Все объекты\',\n'
              '                        subtitle: \'Сводка по всем активным объектам\',\n'
              '                        icon: Icons.apartment_outlined,\n'
              '                        isSelected: selectedValue == _allObjectsValue,\n'
              '                        onTap: () {\n'
              '                          Navigator.pop(sheetContext, _allObjectsValue);\n'
              '                        },\n'
              '                      ),\n'
              '                      ...objects.map((objectName) {\n'
              '                        return _ObjectPickerTile(\n'
              '                          title: objectName,\n'
              '                          subtitle: \'Данные только по этому объекту\',\n'
              '                          icon: Icons.business_outlined,\n'
              '                          isSelected: objectName == selectedValue,\n'
              '                          onTap: () {\n'
              '                            Navigator.pop(sheetContext, objectName);\n'
              '                          },\n'
              '                          onEdit: () {\n'
              '                            Navigator.pop(\n'
              '                              sheetContext,\n'
              '                              \'$_editObjectPrefix$objectName\',\n'
              '                            );\n'
              '                          },\n'
              '                          onArchive: () {\n'
              '                            Navigator.pop(\n'
              '                              sheetContext,\n'
              '                              \'$_archiveObjectPrefix$objectName\',\n'
              '                            );\n'
              '                          },\n'
              '                        );\n'
              '                      }),\n'
              '                    ],\n'
              '                  ),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (!context.mounted) return;\n'
              '    if (pickedValue == null) return;\n'
              '\n'
              '    if (pickedValue == _archiveListValue) {\n'
              '      await showArchivedObjectsSheet(context);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue == _addObjectValue) {\n'
              '      await handleAddObject();\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue.startsWith(_editObjectPrefix)) {\n'
              '      final objectName = pickedValue.substring(_editObjectPrefix.length);\n'
              '      await handleRenameObject(objectName);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue.startsWith(_archiveObjectPrefix)) {\n'
              '      final objectName = pickedValue.substring(_archiveObjectPrefix.length);\n'
              '      await handleArchiveObject(objectName);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue == _allObjectsValue) {\n'
              '      widget.onObjectChanged(null);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    widget.onObjectChanged(pickedValue);\n'
              '  }\n'
              '\n'
              '  Future<void> showFinancePeriodPicker(BuildContext context) async {\n'
              '    if (!widget.profile.isAdmin) return;\n'
              '\n'
              '    final periods = <FinancePeriod>[\n'
              '      const FinancePeriod.allTime(),\n'
              '      ...FinancePeriod.recentMonths(AppState.today, count: 18),\n'
              '    ];\n'
              '\n'
              '    final picked = await showModalBottomSheet<FinancePeriod>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return SafeArea(\n'
              '          child: Container(\n'
              '            margin: const EdgeInsets.all(12),\n'
              '            padding: const EdgeInsets.all(18),\n'
              '            constraints: BoxConstraints(\n'
              '              maxHeight: MediaQuery.of(sheetContext).size.height * 0.82,\n'
              '            ),\n'
              '            decoration: BoxDecoration(\n'
              '              color: _card,\n'
              '              borderRadius: BorderRadius.circular(28),\n'
              '              border: Border.all(color: _line),\n'
              '            ),\n'
              '            child: Column(\n'
              '              mainAxisSize: MainAxisSize.min,\n'
              '              children: [\n'
              '                Row(\n'
              '                  children: [\n'
              '                    const Expanded(\n'
              '                      child: Text(\n'
              '                        \'Период выплат\',\n'
              '                        style: TextStyle(\n'
              '                          color: _text,\n'
              '                          fontSize: 22,\n'
              '                          fontWeight: FontWeight.w900,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                    IconButton(\n'
              '                      onPressed: () => Navigator.pop(sheetContext),\n'
              '                      icon: const Icon(Icons.close),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '                const SizedBox(height: 10),\n'
              '                Flexible(\n'
              '                  child: ListView.builder(\n'
              '                    shrinkWrap: true,\n'
              '                    itemCount: periods.length,\n'
              '                    itemBuilder: (context, index) {\n'
              '                      final period = periods[index];\n'
              '                      final isSelected = isSameFinancePeriod(\n'
              '                        period,\n'
              '                        financePeriod,\n'
              '                      );\n'
              '\n'
              '                      return Padding(\n'
              '                        padding: const EdgeInsets.only(bottom: 10),\n'
              '                        child: InkWell(\n'
              '                          borderRadius: BorderRadius.circular(18),\n'
              '                          onTap: () => Navigator.pop(sheetContext, period),\n'
              '                          child: Container(\n'
              '                            padding: const EdgeInsets.all(14),\n'
              '                            decoration: BoxDecoration(\n'
              '                              color: isSelected ? _softCard : _card,\n'
              '                              borderRadius: BorderRadius.circular(18),\n'
              '                              border: Border.all(\n'
              '                                color: isSelected ? _accent : _line,\n'
              '                              ),\n'
              '                            ),\n'
              '                            child: Row(\n'
              '                              children: [\n'
              '                                Icon(\n'
              '                                  period.isAllTime\n'
              '                                      ? Icons.all_inclusive\n'
              '                                      : Icons.calendar_month_outlined,\n'
              '                                ),\n'
              '                                const SizedBox(width: 12),\n'
              '                                Expanded(\n'
              '                                  child: Text(\n'
              '                                    period.pickerTitle(),\n'
              '                                    style: const TextStyle(\n'
              '                                      color: _text,\n'
              '                                      fontWeight: FontWeight.w900,\n'
              '                                    ),\n'
              '                                  ),\n'
              '                                ),\n'
              '                                if (isSelected)\n'
              '                                  const Icon(\n'
              '                                    Icons.check_circle,\n'
              '                                    color: _accent,\n'
              '                                  ),\n'
              '                              ],\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                      );\n'
              '                    },\n'
              '                  ),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (picked == null || isSameFinancePeriod(picked, financePeriod)) return;\n'
              '\n'
              '    setState(() {\n'
              '      financePeriod = picked;\n'
              '      dashboardFuture = loadDashboardData();\n'
              '    });\n'
              '  }\n'
              '\n'
              '  Widget buildObjectSelector(BuildContext context) {\n'
              '    if (!widget.profile.isAdmin) {\n'
              '      return _ObjectSelectorShell(\n'
              '        icon: Icons.lock_outline,\n'
              '        title: objectTitle,\n'
              '        onTap: null,\n'
              '      );\n'
              '    }\n'
              '\n'
              '    return FutureBuilder<List<String>>(\n'
              '      future: objectNamesFuture,\n'
              '      builder: (context, snapshot) {\n'
              '        final objects = snapshot.data ?? const <String>[];\n'
              '\n'
              '        return _ObjectSelectorShell(\n'
              '          icon: Icons.apartment_outlined,\n'
              '          title: objectTitle,\n'
              '          onTap: () => showObjectPicker(context, objects),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildHeader(BuildContext context, DateTime today) {\n'
              '    return Column(\n'
              '      crossAxisAlignment: CrossAxisAlignment.stretch,\n'
              '      children: [\n'
              '        AppPageHeader(\n'
              '          title: \'Главная\',\n'
              '          subtitle: \'Рабочая сводка по объектам, людям, задачам и выплатам\',\n'
              '          trailing: NotificationBell(\n'
              '            selectedObjectName: widget.selectedObjectName,\n'
              '          ),\n'
              '        ),\n'
              '        const SizedBox(height: 14),\n'
              '        PremiumWorkCard(\n'
              '          radius: 26,\n'
              '          padding: const EdgeInsets.all(16),\n'
              '          child: Column(\n'
              '            crossAxisAlignment: CrossAxisAlignment.stretch,\n'
              '            children: [\n'
              '              Row(\n'
              '                children: [\n'
              '                  const Icon(\n'
              '                    Icons.calendar_month_outlined,\n'
              '                    color: _muted,\n'
              '                    size: 20,\n'
              '                  ),\n'
              '                  const SizedBox(width: 10),\n'
              '                  Text(\n'
              '                    \'Сегодня, ${dateText(today)}\',\n'
              '                    style: const TextStyle(\n'
              '                      color: _muted,\n'
              '                      fontSize: 15,\n'
              '                      fontWeight: FontWeight.w700,\n'
              '                    ),\n'
              '                  ),\n'
              '                ],\n'
              '              ),\n'
              '              const SizedBox(height: 14),\n'
              '              buildObjectSelector(context),\n'
              '            ],\n'
              '          ),\n'
              '        ),\n'
              '      ],\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildDashboard({\n'
              '    required BuildContext context,\n'
              '    required DateTime today,\n'
              '    required List<Employee> employees,\n'
              '    required Set<String> workedEmployeeIds,\n'
              '    required List<TaskItemData> tasks,\n'
              '    required FinanceSummaryData finance,\n'
              '    required bool isLoading,\n'
              '    required bool hasError,\n'
              '  }) {\n'
              '    final employeeById = <String, Employee>{};\n'
              '    final activeEmployeeNames = <String>{};\n'
              '\n'
              '    for (final employee in employees) {\n'
              '      final id = employee.id?.trim();\n'
              '\n'
              '      if (id != null && id.isNotEmpty) {\n'
              '        employeeById[id] = employee;\n'
              '      }\n'
              '\n'
              '      activeEmployeeNames.add(normalizeName(employee.name));\n'
              '    }\n'
              '\n'
              '    final workedEmployeeNames = <String>{};\n'
              '\n'
              '    for (final employeeId in workedEmployeeIds) {\n'
              '      final employee = employeeById[employeeId];\n'
              '\n'
              '      if (employee != null) {\n'
              '        workedEmployeeNames.add(normalizeName(employee.name));\n'
              '      }\n'
              '    }\n'
              '\n'
              '    final totalEmployees = activeEmployeeNames.length;\n'
              '    final workedEmployees = workedEmployeeNames.length;\n'
              '    final totalTasks = tasks.length;\n'
              '    final doneTasks = tasks.where((task) => task.status == \'Выполнено\').length;\n'
              '    final employeesProgress = totalEmployees == 0\n'
              '        ? 0.0\n'
              '        : workedEmployees / totalEmployees;\n'
              '    final tasksProgress = totalTasks == 0 ? 0.0 : doneTasks / totalTasks;\n'
              '\n'
              '    return PremiumWorkBackdrop(\n'
              '      child: SafeArea(\n'
              '        child: ListView(\n'
              '          padding: const EdgeInsets.fromLTRB(18, 18, 18, 120),\n'
              '          children: [\n'
              '            Center(\n'
              '              child: ConstrainedBox(\n'
              '                constraints: const BoxConstraints(maxWidth: 620),\n'
              '                child: Column(\n'
              '                  crossAxisAlignment: CrossAxisAlignment.start,\n'
              '                  children: [\n'
              '                    buildHeader(context, today),\n'
              '                    if (hasError) ...[\n'
              '                      const SizedBox(height: 14),\n'
              '                      const _SystemMessage(\n'
              '                        icon: Icons.error_outline,\n'
              '                        title: \'Есть ошибка загрузки\',\n'
              '                        text:\n'
              '                            \'Часть данных не подтянулась. Обнови страницу или проверь интернет.\',\n'
              '                      ),\n'
              '                    ],\n'
              '                    const SizedBox(height: 24),\n'
              '                    _DashboardMetricCard(\n'
              '                      icon: Icons.person_outline,\n'
              '                      title: \'Сотрудники на объекте\',\n'
              '                      value: isLoading ? \'...\' : workedEmployees.toString(),\n'
              '                      secondaryValue: isLoading ? \'...\' : \'из $totalEmployees\',\n'
              '                      progress: employeesProgress,\n'
              '                      footerTitle: \'На объекте\',\n'
              '                      footerValue: isLoading\n'
              '                          ? \'...\'\n'
              '                          : workedEmployees.toString(),\n'
              '                      footerColor: _success,\n'
              '                    ),\n'
              '                    const SizedBox(height: 14),\n'
              '                    _DashboardMetricCard(\n'
              '                      icon: Icons.assignment_turned_in_outlined,\n'
              '                      title: \'Задачи на сегодня\',\n'
              '                      value: isLoading ? \'...\' : totalTasks.toString(),\n'
              '                      secondaryValue: \'всего\',\n'
              '                      progress: tasksProgress,\n'
              '                      footerTitle: \'Выполнено\',\n'
              '                      footerValue: isLoading ? \'...\' : doneTasks.toString(),\n'
              '                      footerColor: _accent,\n'
              '                    ),\n'
              '                    if (widget.profile.isAdmin) ...[\n'
              '                      const SizedBox(height: 14),\n'
              '                      _FinanceSummaryCard(\n'
              '                        title: \'Выплаты ${financePeriod.title()}\',\n'
              '                        objectTitle: objectTitle,\n'
              '                        finance: isLoading ? FinanceSummaryData.empty : finance,\n'
              '                        isLoading: isLoading,\n'
              '                        onPeriodTap: () => showFinancePeriodPicker(context),\n'
              '                      ),\n'
              '                    ],\n'
              '                  ],\n'
              '                ),\n'
              '              ),\n'
              '            ),\n'
              '          ],\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    final today = AppState.today;\n'
              '\n'
              '    return FutureBuilder<_HomeDashboardData>(\n'
              '      future: dashboardFuture,\n'
              '      builder: (context, snapshot) {\n'
              '        final data = snapshot.data ?? _HomeDashboardData.empty;\n'
              '        final isLoading =\n'
              '            snapshot.connectionState == ConnectionState.waiting &&\n'
              '            !snapshot.hasData;\n'
              '\n'
              '        return buildDashboard(\n'
              '          context: context,\n'
              '          today: today,\n'
              '          employees: data.employees,\n'
              '          workedEmployeeIds: data.workedEmployeeIds,\n'
              '          tasks: data.tasks,\n'
              '          finance: data.finance,\n'
              '          isLoading: isLoading,\n'
              '          hasError: snapshot.hasError,\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class _HomeDashboardData {\n'
              '  final List<Employee> employees;\n'
              '  final Set<String> workedEmployeeIds;\n'
              '  final List<TaskItemData> tasks;\n'
              '  final FinanceSummaryData finance;\n'
              '\n'
              '  const _HomeDashboardData({\n'
              '    required this.employees,\n'
              '    required this.workedEmployeeIds,\n'
              '    required this.tasks,\n'
              '    required this.finance,\n'
              '  });\n'
              '\n'
              '  static const empty = _HomeDashboardData(\n'
              '    employees: <Employee>[],\n'
              '    workedEmployeeIds: <String>{},\n'
              '    tasks: <TaskItemData>[],\n'
              '    finance: FinanceSummaryData.empty,\n'
              '  );\n'
              '}\n'
              '\n'
              'class _ObjectSelectorShell extends StatelessWidget {\n'
              '  final IconData icon;\n'
              '  final String title;\n'
              '  final VoidCallback? onTap;\n'
              '\n'
              '  const _ObjectSelectorShell({\n'
              '    required this.icon,\n'
              '    required this.title,\n'
              '    required this.onTap,\n'
              '  });\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    return InkWell(\n'
              '      borderRadius: BorderRadius.circular(24),\n'
              '      onTap: onTap,\n'
              '      child: Container(\n'
              '        width: double.infinity,\n'
              '        padding: const EdgeInsets.all(14),\n'
              '        decoration: BoxDecoration(\n'
              '          color: _card,\n'
              '          borderRadius: BorderRadius.circular(24),\n'
              '          border: Border.all(color: _line),\n'
              '          boxShadow: [\n'
              '            BoxShadow(\n'
              '              color: Colors.black.withValues(alpha: 0.035),\n'
              '              blurRadius: 18,\n'
              '              offset: const Offset(0, 9),\n'
              '            ),\n'
              '          ],\n'
              '        ),\n'
              '        child: Row(\n'
              '          children: [\n'
              '            _IconBox(icon: icon, color: _text),\n'
              '            const SizedBox(width: 12),\n'
              '            Expanded(\n'
              '              child: Text(\n'
              '                title,\n'
              '                overflow: TextOverflow.ellipsis,\n'
              '                style: const TextStyle(\n'
              '                  color: _text,\n'
              '                  fontSize: 18,\n'
              '                  fontWeight: FontWeight.w800,\n'
              '                ),\n'
              '              ),\n'
              '            ),\n'
              '            if (onTap != null)\n'
              '              const Icon(Icons.keyboard_arrow_down, color: _text),\n'
              '          ],\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class _ObjectPickerTile extends StatelessWidget {\n'
              '  final String title;\n'
              '  final String subtitle;\n'
              '  final IconData icon;\n'
              '  final bool isSelected;\n'
              '  final VoidCallback onTap;\n'
              '  final VoidCallback? onEdit;\n'
              '  final VoidCallback? onArchive;\n'
              '\n'
              '  const _ObjectPickerTile({\n'
              '    required this.title,\n'
              '    required this.subtitle,\n'
              '    required this.icon,\n'
              '    required this.isSelected,\n'
              '    required this.onTap,\n'
              '    this.onEdit,\n'
              '    this.onArchive,\n'
              '  });\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    return Padding(\n'
              '      padding: const EdgeInsets.only(bottom: 10),\n'
              '      child: InkWell(\n'
              '        borderRadius: BorderRadius.circular(20),\n'
              '        onTap: onTap,\n'
              '        child: Container(\n'
              '          padding: const EdgeInsets.fromLTRB(14, 12, 8, 12),\n'
              '          decoration: BoxDecoration(\n'
              '            color: isSelected ? _softCard : _card,\n'
              '            borderRadius: BorderRadius.circular(20),\n'
              '            border: Border.all(color: isSelected ? _accent : _line),\n'
              '          ),\n'
              '          child: Row(\n'
              '            children: [\n'
              '              _IconBox(icon: icon, color: isSelected ? _accent : _text),\n'
              '              const SizedBox(width: 12),\n'
              '              Expanded(\n'
              '                child: Column(\n'
              '                  crossAxisAlignment: CrossAxisAlignment.start,\n'
              '                  children: [\n'
              '                    Text(\n'
              '                      title,\n'
              '                      overflow: TextOverflow.ellipsis,\n'
              '                      style: const TextStyle(\n'
              '                        color: _text,\n'
              '                        fontSize: 16,\n'
              '                        fontWeight: FontWeight.w900,\n'
              '                      ),\n'
              '                    ),\n'
              '                    const SizedBox(height: 2),\n'
              '                    Text(\n'
              '                      subtitle,\n'
              '                      overflow: TextOverflow.ellipsis,\n'
              '                      style: const TextStyle(\n'
              '                        color: _muted,\n'
              '                        fontWeight: FontWeight.w600,\n'
              '                      ),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '              ),\n'
              '              if (onEdit != null)\n'
              '                IconButton(\n'
              '                  visualDensity: VisualDensity.compact,\n'
              '                  tooltip: \'Редактировать объект\',\n'
              '                  onPressed: onEdit,\n'
              '                  icon: const Icon(Icons.edit_outlined, size: 20),\n'
              '                ),\n'
              '              if (onArchive != null)\n'
              '                IconButton(\n'
              '                  visualDensity: VisualDensity.compact,\n'
              '                  tooltip: \'Архивировать объект\',\n'
              '                  onPressed: onArchive,\n'
              '                  icon: const Icon(Icons.archive_outlined, size: 20),\n'
              '                ),\n'
              '              if (isSelected)\n'
              '                const Padding(\n'
              '                  padding: EdgeInsets.only(right: 4),\n'
              '                  child: Icon(Icons.check_circle, color: _accent),\n'
              '                ),\n'
              '            ],\n'
              '          ),\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class _DashboardMetricCard extends StatelessWidget {\n'
              '  final IconData icon;\n'
              '  final String title;\n'
              '  final String value;\n'
              '  final String secondaryValue;\n'
              '  final double progress;\n'
              '  final String footerTitle;\n'
              '  final String footerValue;\n'
              '  final Color footerColor;\n'
              '\n'
              '  const _DashboardMetricCard({\n'
              '    required this.icon,\n'
              '    required this.title,\n'
              '    required this.value,\n'
              '    required this.secondaryValue,\n'
              '    required this.progress,\n'
              '    required this.footerTitle,\n'
              '    required this.footerValue,\n'
              '    required this.footerColor,\n'
              '  });\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    final safeProgress = progress.clamp(0.0, 1.0).toDouble();\n'
              '\n'
              '    return PremiumWorkCard(\n'
              '      radius: 28,\n'
              '      child: Row(\n'
              '        crossAxisAlignment: CrossAxisAlignment.start,\n'
              '        children: [\n'
              '          _IconBox(icon: icon, color: _accent),\n'
              '          const SizedBox(width: 16),\n'
              '          Expanded(\n'
              '            child: Column(\n'
              '              crossAxisAlignment: CrossAxisAlignment.start,\n'
              '              children: [\n'
              '                Text(\n'
              '                  title,\n'
              '                  style: const TextStyle(\n'
              '                    color: _text,\n'
              '                    fontSize: 18,\n'
              '                    fontWeight: FontWeight.w800,\n'
              '                  ),\n'
              '                ),\n'
              '                const SizedBox(height: 18),\n'
              '                Row(\n'
              '                  crossAxisAlignment: CrossAxisAlignment.end,\n'
              '                  children: [\n'
              '                    Text(\n'
              '                      value,\n'
              '                      style: const TextStyle(\n'
              '                        color: _text,\n'
              '                        fontSize: 44,\n'
              '                        height: 0.95,\n'
              '                        fontWeight: FontWeight.w900,\n'
              '                      ),\n'
              '                    ),\n'
              '                    const SizedBox(width: 8),\n'
              '                    Padding(\n'
              '                      padding: const EdgeInsets.only(bottom: 4),\n'
              '                      child: Text(\n'
              '                        secondaryValue,\n'
              '                        style: const TextStyle(\n'
              '                          color: _muted,\n'
              '                          fontWeight: FontWeight.w700,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '                const SizedBox(height: 16),\n'
              '                ClipRRect(\n'
              '                  borderRadius: BorderRadius.circular(999),\n'
              '                  child: LinearProgressIndicator(\n'
